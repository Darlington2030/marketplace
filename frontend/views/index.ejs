<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="CollectMarket — Rare collectibles marketplace. Negotiate prices directly with sellers."/>
  <title><%= title %></title>

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        screens: { xs:'480px', sm:'640px', md:'768px', lg:'1024px', xl:'1280px' },
        extend: {
          fontFamily: {
            display: ['"Playfair Display"','Georgia','serif'],
            sans:    ['"DM Sans"','system-ui','sans-serif'],
          },
          keyframes: {
            fadeUp:   { from:{ opacity:'0', transform:'translateY(18px)' }, to:{ opacity:'1', transform:'translateY(0)' } },
            fadeIn:   { from:{ opacity:'0' }, to:{ opacity:'1' } },
            pulseDot: { '0%,100%':{ opacity:'1', transform:'scale(1)' }, '50%':{ opacity:'.5', transform:'scale(1.5)' } },
            float:    { '0%,100%':{ transform:'translateY(0)' }, '50%':{ transform:'translateY(-8px)' } },
            spin:     { to:{ transform:'rotate(360deg)' } },
          },
          animation: {
            'fade-up':   'fadeUp .55s ease-out both',
            'fade-up-1': 'fadeUp .55s .12s ease-out both',
            'fade-up-2': 'fadeUp .55s .24s ease-out both',
            'fade-up-3': 'fadeUp .55s .36s ease-out both',
            'fade-in':   'fadeIn .45s ease-out both',
            'pulse-dot': 'pulseDot 2s ease-in-out infinite',
            'float':     'float 3.2s ease-in-out infinite',
          },
        }
      }
    }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet"/>

  <script>window.__API_BASE__ = '<%= apiBase %>';</script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', system-ui, sans-serif;
      background: #07070f;
      color: white;
      min-height: 100vh;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* Scrollbars */
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 99px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,.22); }

    /* Placeholders */
    ::placeholder { color: rgba(255,255,255,.22); }

    /* Lit element display */
    header-auth       { display: inline-flex; align-items: center; }
    search-bar        { display: block; width: 100%; }
    item-grid         { display: block; }
    item-card         { display: block; }
    auth-modal,
    list-item-modal,
    chat-panel,
    item-detail-modal,
    toast-notification { display: block; }

    /* Chat scrollbar */
    .chat-msgs::-webkit-scrollbar { width: 3px; }
    .chat-msgs::-webkit-scrollbar-thumb { background: rgba(255,255,255,.08); border-radius: 99px; }

    /* Focus ring */
    :focus-visible { outline: 2px solid rgba(245,158,11,.55); outline-offset: 2px; border-radius: 6px; }


    /* ── Global input/textarea text visibility fix ── */
    /* Overrides browser UA stylesheet that sets input color to system default */
    input, textarea, select {
      color: white !important;
      -webkit-text-fill-color: white !important;
      caret-color: white !important;
    }
    input::placeholder, textarea::placeholder {
      color: rgba(255,255,255,0.3) !important;
      -webkit-text-fill-color: rgba(255,255,255,0.3) !important;
      opacity: 1 !important;
    }
    /* Autofill override (Chrome sets yellow bg + dark text) */
    input:-webkit-autofill,
    input:-webkit-autofill:hover,
    input:-webkit-autofill:focus {
      -webkit-box-shadow: 0 0 0 100px rgba(25,25,50,0.98) inset !important;
      -webkit-text-fill-color: white !important;
      caret-color: white !important;
    }

    /* Disable number input spinners */
    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; }

    /* Grain texture */
    .grain::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 2;
      opacity: .022;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 200px;
    }

    /* ─── HEADER: NO backdrop-filter so position:fixed children work normally ─── */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 40;
      /* Solid dark background — avoids creating a CSS stacking context */
      background: rgba(7, 7, 15, 0.96);
      border-bottom: 1px solid rgba(255,255,255,.06);
      /* No backdrop-filter here — it would trap fixed-position modal children */
    }
  </style>
</head>

<body class="bg-[#07070f] text-white min-h-screen">

  <!-- Ambient background glows -->
  <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute -top-40 -left-32 w-[700px] h-[700px] rounded-full bg-amber-500/[.05] blur-[140px]"></div>
    <div class="absolute -bottom-40 -right-32 w-[600px] h-[600px] rounded-full bg-violet-600/[.045] blur-[140px]"></div>
  </div>

  <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:px-4 focus:py-2 focus:bg-amber-500 focus:text-white focus:rounded-xl focus:text-sm focus:font-semibold">
    Skip to content
  </a>

  <!-- ═══════════════════════════════════════════
       HEADER — 3-column grid: logo | search | actions
       NOTE: No backdrop-filter (would trap position:fixed modals)
  ═══════════════════════════════════════════ -->
  <header class="site-header" role="banner">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Desktop: true 3-column grid -->
      <div class="hidden sm:grid h-16 items-center gap-4" style="grid-template-columns: 1fr minmax(0,420px) 1fr">

        <!-- Logo (left) -->
        <div class="flex items-center">
          <a href="/" aria-label="CollectMarket home"
            class="flex items-center gap-2.5 group focus-visible:outline-none">
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-amber-400 to-orange-600 flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-amber-500/25 group-hover:scale-105 group-hover:-rotate-3 transition-all duration-200">◈</div>
            <span class="font-bold text-white text-lg tracking-tight hidden md:block" style="font-family:'Playfair Display',serif">
              Collect<span class="text-amber-400">Market</span>
            </span>
          </a>
        </div>

        <!-- Search (center) -->
        <div role="search" aria-label="Search marketplace">
          <% if (components.includes('search-bar')) { %><search-bar></search-bar><% } %>
        </div>

        <!-- Actions (right) -->
        <div class="flex items-center justify-end gap-2.5">
          <button
            id="list-item-btn"
            class="flex items-center gap-2 px-4 py-2 text-sm font-medium bg-white/[.05] border border-white/[.1] text-white/60 hover:text-white hover:bg-white/[.09] hover:border-white/[.2] rounded-full transition-all duration-200 whitespace-nowrap cursor-pointer"
            aria-label="List a new item for sale">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
            List Item
          </button>
          <!-- header-auth: shows Sign In button or user pill — NO modals rendered here -->
          <% if (components.includes('auth-modal')) { %><header-auth></header-auth><% } %>
        </div>
      </div>

      <!-- Mobile row -->
      <div class="flex sm:hidden h-14 items-center gap-3">
        <a href="/" class="flex items-center gap-2 shrink-0">
          <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-amber-400 to-orange-600 flex items-center justify-center text-white font-bold text-base shadow-lg shadow-amber-500/25">◈</div>
          <span class="font-bold text-white text-base" style="font-family:'Playfair Display',serif">Collect<span class="text-amber-400">M</span></span>
        </a>
        <div class="flex-1"></div>
        <button
          id="list-item-btn"
          class="flex items-center gap-1.5 px-3 py-2 text-xs font-medium bg-white/[.05] border border-white/[.1] text-white/60 hover:text-white rounded-full transition-all cursor-pointer"
          aria-label="List item">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
          List
        </button>
        <% if (components.includes('auth-modal')) { %><header-auth></header-auth><% } %>
      </div>

      <!-- Mobile search row -->
      <div class="sm:hidden pb-3" role="search">
        <% if (components.includes('search-bar')) { %><search-bar></search-bar><% } %>
      </div>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section class="relative overflow-hidden border-b border-white/[.05] grain" aria-label="Hero">
    <div class="absolute inset-0 z-0" aria-hidden="true">
      <img src="https://images.unsplash.com/photo-1555680202-c86f0e12f086?w=1600&q=72"
           alt="" class="w-full h-full object-cover opacity-[.09]" loading="eager"/>
      <div class="absolute inset-0" style="background:linear-gradient(to right,#07070f 38%,rgba(7,7,15,.72) 68%,rgba(7,7,15,.28) 100%)"></div>
      <div class="absolute inset-0" style="background:linear-gradient(to top,#07070f 0%,transparent 50%)"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-14">

        <!-- Copy -->
        <div class="flex-1 max-w-xl text-center lg:text-left">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 bg-amber-500/10 border border-amber-500/20 rounded-full mb-6 animate-fade-up">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse-dot"></span>
            <span class="text-xs font-semibold text-amber-400/90">Live marketplace · New listings daily</span>
          </div>

          <h1 class="font-bold text-white mb-5 leading-[1.08] tracking-tight animate-fade-up-1"
              style="font-family:'Playfair Display',serif;font-size:clamp(2.1rem,5.5vw,3.8rem)">
            Rare Finds.<br/>
            <span class="text-transparent bg-clip-text" style="background-image:linear-gradient(135deg,#fbbf24,#f97316)">Fair Deals.</span>
          </h1>

          <p class="text-white/50 text-base sm:text-lg leading-relaxed mb-8 max-w-md mx-auto lg:mx-0 animate-fade-up-2">
            The collector's marketplace for comics, cards, figures&nbsp;&amp;&nbsp;more.
            Negotiate <span class="text-white/72 font-medium">directly</span> with sellers via live chat.
          </p>

          <div class="flex flex-wrap gap-3 justify-center lg:justify-start mb-10 animate-fade-up-2">
            <button onclick="document.getElementById('main').scrollIntoView({behavior:'smooth'})"
              class="px-6 py-3 text-sm font-semibold text-white rounded-full border-none cursor-pointer transition-all"
              style="background:linear-gradient(135deg,#f59e0b,#ea580c);box-shadow:0 6px 20px rgba(245,158,11,0.28)">
              Browse Listings
            </button>
            <button id="hero-sell-btn"
              class="px-6 py-3 text-sm font-semibold text-white/70 bg-white/[.06] border border-white/[.12] rounded-full hover:bg-white/[.1] hover:text-white transition-all cursor-pointer">
              Start Selling
            </button>
          </div>

          <div class="flex flex-wrap justify-center lg:justify-start gap-x-8 gap-y-3 animate-fade-up-3">
            <div class="text-center lg:text-left">
              <p class="text-2xl font-bold text-amber-400" style="font-family:'Playfair Display',serif">6+</p>
              <p class="text-[10px] uppercase tracking-widest text-white/30 mt-0.5">Active Listings</p>
            </div>
            <div class="hidden sm:block w-px h-9 bg-white/[.08] self-center"></div>
            <div class="text-center lg:text-left">
              <p class="text-2xl font-bold text-amber-400" style="font-family:'Playfair Display',serif">Live</p>
              <p class="text-[10px] uppercase tracking-widest text-white/30 mt-0.5">Negotiation</p>
            </div>
            <div class="hidden sm:block w-px h-9 bg-white/[.08] self-center"></div>
            <div class="text-center lg:text-left">
              <p class="text-2xl font-bold text-amber-400" style="font-family:'Playfair Display',serif">Secure</p>
              <p class="text-[10px] uppercase tracking-widest text-white/30 mt-0.5">Checkout</p>
            </div>
          </div>
        </div>

        <!-- Hero product card (tablet/desktop) -->
        <div class="hidden md:block relative shrink-0 w-80 lg:w-[380px] xl:w-[420px] animate-fade-in" aria-hidden="true">
          <div class="relative rounded-2xl overflow-hidden border border-white/[.1]" style="box-shadow:0 24px 60px rgba(0,0,0,0.6)">
            <img src="https://images.unsplash.com/photo-1621274403997-37aace184f49?w=700&q=80"
                 alt="Pokémon Charizard collectible" class="w-full object-cover" style="height:280px"/>
            <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(13,13,31,.95) 0%,rgba(13,13,31,.15) 45%,transparent 100%)"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5">
              <div class="flex items-end justify-between">
                <div>
                  <span class="inline-block px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-amber-400 bg-amber-500/15 border border-amber-500/25 rounded-full mb-2">Featured</span>
                  <p class="text-sm font-semibold text-white leading-snug">Pokémon Charizard<br/>1st Edition Holo</p>
                </div>
                <div class="text-right">
                  <p class="text-[10px] text-white/38 mb-1">Asking</p>
                  <p class="text-xl font-bold text-amber-400" style="font-family:'Playfair Display',serif">$1,200</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating: offer received -->
          <div class="absolute -top-5 -right-5 xl:-right-7 flex items-center gap-2.5 px-3.5 py-2.5 rounded-2xl border border-white/[.1] animate-float"
               style="background:rgba(13,13,31,.96);box-shadow:0 12px 32px rgba(0,0,0,0.5)">
            <div class="w-8 h-8 rounded-xl flex items-center justify-center text-sm shrink-0" style="background:linear-gradient(135deg,#f59e0b,#ea580c)">💬</div>
            <div>
              <p class="text-[10px] text-white/38 mb-0.5">Offer received</p>
              <p class="text-xs font-semibold text-white">$950 from ToyTrader</p>
            </div>
          </div>

          <!-- Floating: sale confirmed -->
          <div class="absolute -bottom-5 -left-5 xl:-left-7 flex items-center gap-2.5 px-3.5 py-2.5 rounded-2xl border border-white/[.1] animate-float"
               style="background:rgba(13,13,31,.96);box-shadow:0 12px 32px rgba(0,0,0,0.5);animation-delay:.9s">
            <div class="w-8 h-8 rounded-xl flex items-center justify-center text-sm shrink-0" style="background:linear-gradient(135deg,#10b981,#0d9488)">✓</div>
            <div>
              <p class="text-[10px] text-white/38 mb-0.5">Sale confirmed</p>
              <p class="text-xs font-semibold text-white">Spider-Man #1 sold!</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       MAIN — Listings
  ═══════════════════════════════════════════ -->
  <main id="main" class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10 pb-28">
    <div class="flex items-center gap-2.5 mb-6 pb-5 border-b border-white/[.06]">
      <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse-dot"></span>
      <h2 class="text-sm font-semibold text-white/48 uppercase tracking-wider">All Listings</h2>
    </div>
    <% if (components.includes('item-grid')) { %><item-grid></item-grid><% } %>
  </main>

  <!-- ═══════════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════════ -->
  <footer class="relative z-10 border-t border-white/[.05] py-6" role="contentinfo">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-center sm:text-left">
      <div class="flex items-center gap-2">
        <span class="text-amber-500">◈</span>
        <span class="text-sm font-semibold text-white/35" style="font-family:'Playfair Display',serif">CollectMarket</span>
        <span class="text-xs text-white/20">© 2025</span>
      </div>
      <div class="flex items-center gap-4 text-xs text-white/22">
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse-dot"></span>Live</span>
        <span>·</span><span>Secure Checkout</span><span>·</span><span>Direct Negotiation</span>
      </div>
    </div>
  </footer>

  <!-- ═══════════════════════════════════════════
       LIT MODALS — all at <body> level
       auth-modal is HERE (not inside header) so position:fixed works correctly
  ═══════════════════════════════════════════ -->
  <% if (components.includes('auth-modal')) { %><auth-modal></auth-modal><% } %>
  <% if (components.includes('list-item-modal')) { %><list-item-modal></list-item-modal><% } %>
  <% if (components.includes('chat-panel')) { %><chat-panel></chat-panel><% } %>
  <% if (components.includes('item-detail-modal')) { %><item-detail-modal></item-detail-modal><% } %>
  <% if (components.includes('toast-notification')) { %><toast-notification></toast-notification><% } %>

  <script type="module" src="/dist/main.js"></script>
</body>
</html>
