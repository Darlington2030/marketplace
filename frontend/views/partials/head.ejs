<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content="Collectibles Social Marketplace — buy, sell, negotiate rare items" />
<title><%= typeof title !== 'undefined' ? title + ' · ' : '' %>◈ Bazaar</title>

<!-- Tailwind CSS CDN (for development; production uses vite build) -->
<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          display: ['"Playfair Display"', 'Georgia', 'serif'],
          body: ['"DM Sans"', 'system-ui', 'sans-serif'],
        },
      },
    },
  };
</script>

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

<!-- Inject API base for client -->
<script>window.__API_BASE__ = "<%= apiBase %>";</script>

<style>
  *, *::before, *::after { box-sizing: border-box; }

  html {
    font-family: 'DM Sans', system-ui, sans-serif;
    background: #07070f;
    color: #f0f0f5;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    background:
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(245,158,11,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 80%, rgba(234,88,12,0.05) 0%, transparent 50%),
      #07070f;
    background-attachment: fixed;
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 9999px; }
  ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }

  /* Lit components display fix */
  auth-modal, search-bar, item-card, item-grid,
  list-item-modal, chat-panel, checkout-modal { display: block; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-in { animation: fadeIn 0.4s ease forwards; }
</style>
